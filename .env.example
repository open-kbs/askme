GOOGLE_OAUTH_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com
# Vite exposes this to the frontend (mirrored from GOOGLE_OAUTH_CLIENT_ID).
# The setup API sets it automatically; manual users must add it too.
VITE_GOOGLE_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com
GOOGLE_SERVICE_ACCOUNT_KEY=base64_of_service_account_json
GOOGLE_CALENDAR_IDS=owner@example.com,work@example.com
GOOGLE_CALENDAR_WRITE_ID=owner@example.com
BOOKING_SECRET=hex_for_hmac_sha256
APP_URL=https://your-cloudfront-domain
CONTACT_EMAIL=owner@example.com
FROM_EMAIL=no-reply@openkbs.com

# LLM key — set ONE of these. OPENAI_API_KEY talks to OpenAI directly;
# OPENKBS_API_KEY routes through the OpenKBS proxy (one key for OpenAI +
# Anthropic + Google). In production, the platform injects OPENKBS_API_KEY.
OPENAI_API_KEY=
OPENKBS_API_KEY=

# Local dev only — overrides for the in-process API server (local/server.mjs).
# Defaults are fine; uncomment to change.
# LOCAL_PORT=8787
# LOCAL_DB_FILE=./local/.pgdata
