node_modules/
.*
!.gitignore
!.claude
!.env.example

# Bundled-at-deploy-time artifacts — each function gets a copy of _shared/ + _env.mjs
# written by scripts/deploy-fn.sh. Never commit the copies.
functions/*/_shared/
functions/*/_env.mjs
functions/*/*.zip

# Vite intermediate build artifacts (the final ./site/ IS committed)
site-src/dist/
site-src/node_modules/
site-src/tsconfig*.tsbuildinfo
