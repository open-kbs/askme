node_modules/
.*
!.gitignore
!.github
!.claude
.claude/skills/openkbs/
!.env.example

# Bundled-at-deploy-time artifacts — each function gets a copy of _shared/ + _env.mjs.
# Never commit the copies.
functions/*/_shared/
functions/*/_env.mjs
functions/*/*.zip

# Build output — regenerated by npm run build
site/
dist/
build/
coverage/

# Vite intermediate build artifacts
site-src/dist/
site-src/node_modules/
site-src/tsconfig*.tsbuildinfo
