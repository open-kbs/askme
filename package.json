{
  "name": "openkbs-personal-ai-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Open-source template for a chat-first personal site on OpenKBS",
  "license": "MIT",
  "scripts": {
    "postinstall": "npm --prefix site-src install",
    "dev": "concurrently -n api,web -c cyan,magenta \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "node local/server.mjs",
    "dev:web": "npm --prefix site-src run dev",
    "build": "npm --prefix site-src run build",
    "predeploy": "bash scripts/bundle-functions.sh",
    "deploy": "npm run build && npm run predeploy && openkbs deploy"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.2.13",
    "@hono/node-server": "^1.13.7",
    "dotenv": "^17.4.2",
    "hono": "^4.6.14",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
